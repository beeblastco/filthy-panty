# Optional local SST CLI settings.
# SST loads `.env` into `process.env` for `sst.config.ts`, but this repo does
# not use `.env` as the source of truth for deployed Lambda secrets.
AWS_PROFILE=default
SST_STAGE=dev

# For deployed or `sst dev` usage, set these through SST secrets instead:
#   sst secret set GoogleApiKey ...
#   sst secret set TavilyApiKey ...
#   sst secret set TelegramBotToken ...
#   sst secret set TelegramWebhookSecret ...
#   sst secret set AllowedChatIds ...
#
# Or create `secrets.env` from `secrets.env.example` and run:
#   sst secret load ./secrets.env

# Advanced: only set these if you are running the built Lambda handler outside SST.
# In normal SST workflows these are injected automatically from `sst.config.ts`
# and the Lambda runtime.
# AWS_REGION=eu-central-1
# GOOGLE_API_KEY=your-google-api-key
# TAVILY_API_KEY=your-tavily-api-key
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_WEBHOOK_SECRET=choose-a-random-shared-secret
# ALLOWED_CHAT_IDS=123456789
# GOOGLE_MODEL_ID=gemma-4-31b-it
# SLIDING_CONTEXT_WINDOW=20
# MAX_AGENT_ITERATIONS=20
# TELEGRAM_REACTION_EMOJI=👀
# CONVERSATIONS_TABLE_NAME=your-conversations-table-name
# PROCESSED_EVENTS_TABLE_NAME=your-processed-events-table-name
# AWS_S3_BUCKET=your-memory-bucket-name
