# Local SST config only.
# SST loads `.env` into `process.env` for `sst.config.ts`.
# Do not put deployed secrets in `.env`; use SST secrets instead.
AWS_PROFILE=default
SST_STAGE=dev

# Enable optional channel integrations for local `sst dev` or `sst deploy`.
ENABLE_DIRECT_API=false
ENABLE_TELEGRAM_INTEGRATION=false
ENABLE_GITHUB_INTEGRATION=false
ENABLE_SLACK_INTEGRATION=false
ENABLE_DISCORD_INTEGRATION=false

# Optional non-secret allow-lists read by `sst.config.ts`.
# In non-dev stages these must be explicitly set when the integration is enabled.
# For local dev you may set `open` intentionally.
# GITHUB_ALLOWED_REPOS=owner/repo-a,owner/repo-b
# SLACK_ALLOWED_CHANNEL_IDS=C0123456789,C0987654321
# DISCORD_ALLOWED_GUILD_IDS=123456789012345678,987654321098765432

# Discord slash command sync settings.
# DISCORD_APPLICATION_ID=your-discord-application-id
# DISCORD_SYNC_GUILD_ID=your-development-guild-id

# Secrets belong in SST, not here:
#   bunx sst secret set GoogleApiKey <value>
#   bunx sst secret set TavilyApiKey <value>
#
# Or bulk-load them:
#   cp secrets.env.example secrets.env
#   bunx sst secret load ./secrets.env

# Manual direct API probe scripts in `scripts/manual/` use these local-only values.
# FUNCTION_URL=https://your-function-url.lambda-url...
# DIRECT_API_SECRET=your-shared-secret

# testing local only
FUNCTION_URL=https://your-function-url.lambda-url...
DIRECT_API_SECRET=your-shared-secret
