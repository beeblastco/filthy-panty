# Local SST CLI settings.
# SST loads `.env` into `process.env` for `sst.config.ts`.
AWS_PROFILE=default
SST_STAGE=dev

# Deploy-time SST secrets belong in SST, not `.env`:
#   bunx sst secret set GoogleApiKey <value>
#   bunx sst secret set TavilyApiKey <value>
#   bunx sst secret set AdminAccountSecret <long-random-value>
#   bunx sst secret set AccountConfigEncryptionSecret <long-random-value>
#
# Or bulk-load them:
#   cp secrets.env.example secrets.env
#   bunx sst secret load ./secrets.env

# Manual direct API probe scripts in `scripts/manual/` use these local-only values.
# AGENT_SERVICE_URL=https://your-agent-service-url.lambda-url...
# ACCOUNT_SERVICE_URL=https://your-account-service-url.lambda-url...
# They create and delete a temporary account for each probe run.

# Manual Discord slash command sync reads local environment values.
# DISCORD_APPLICATION_ID=your-discord-application-id
# DISCORD_SYNC_GUILD_ID=your-development-guild-id
# DISCORD_BOT_TOKEN=your-discord-bot-token

# Telegram account configuration helper inputs are normally provided through
# GitHub Actions secrets. For one-off local runs, export them in your shell:
#   ADMIN_ACCOUNT_SECRET=...
#   TELEGRAM_BOT_TOKEN=...
#   TELEGRAM_WEBHOOK_SECRET=...
#   ALLOWED_CHAT_IDS=123456789,987654321
