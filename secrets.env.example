# SST secret values for `sst secret load`.
# Copy this file to `secrets.env`, fill in your values, then run:
#   bunx sst secret load ./secrets.env
#
# These keys are SST secret names from `sst.config.ts`, not Lambda runtime
# environment variable names and not root `.env` keys.

GoogleApiKey=your-google-api-key

TavilyApiKey=your-tavily-api-key

AdminAccountSecret=choose-a-long-random-admin-secret
AccountConfigEncryptionSecret=choose-a-long-random-encryption-secret

# Provider bot tokens, signing secrets, and allow-lists now live in account config,
# not SST secrets.
