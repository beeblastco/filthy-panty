# Copy this file to `secrets.env`, fill in your values, then run:
#   sst secret load ./secrets.env
#
# These keys are SST secret names from `sst.config.ts`, not Lambda runtime
# environment variable names.

GoogleApiKey=your-google-api-key

# Need when you want to enable tavily websearch
TavilyApiKey=your-tavily-api-key

# Only needed when ENABLE_TELEGRAM_INTEGRATION=true:
# TelegramBotToken=your-telegram-bot-token
# TelegramWebhookSecret=choose-a-random-shared-secret
# AllowedChatIds=123456789

# Only needed when ENABLE_GITHUB_INTEGRATION=true:
# GitHubWebhookSecret=choose-a-random-shared-secret
# GitHubAppId=123456
# GitHubPrivateKey="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Only needed when ENABLE_SLACK_INTEGRATION=true:
# SlackBotToken=xoxb-your-slack-bot-token
# SlackSigningSecret=your-slack-signing-secret

# Only needed when ENABLE_DISCORD_INTEGRATION=true:
# DiscordBotToken=your-discord-bot-token
# DiscordPublicKey=your-discord-public-key
