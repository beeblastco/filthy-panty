# Deployed Function URLs the SDK client targets (from `sst deploy` outputs: accountServiceUrl / agentServiceUrl).
ACCOUNT_SERVICE_URL=
AGENT_SERVICE_URL=

# Model + tool keys the demo accounts are configured with.
# A Google key is enough for most demos; the others are only needed by the
# demos that exercise those providers/tools.
ACCOUNT_GOOGLE_API_KEY=
# ACCOUNT_MINIMAX_API_KEY=
# ACCOUNT_TAVILY_API_KEY=

# Mock webhook Function URL + secret (webhook demos; from the deploy output).
# MOCK_WEBHOOK_URL=
# MOCK_WEBHOOK_SECRET=

# Sandbox provider credentials — only for the matching sandbox-* demos.
# DAYTONA_API_KEY=
# DAYTONA_ORGANIZATION_ID=
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_ID=
# E2B_API_KEY=
# E2B_TEMPLATE=

# Optional overrides for the Kubernetes sandbox demos.
# KUBERNETES_SANDBOX_NAMESPACE=
# KUBERNETES_SANDBOX_IMAGE_PULL_SECRETS=

# Optional timezone for the cron-job demo.
# CRON_TIMEZONE=
