# Env for the sandbox-stateless demo (declarative / Convex-style).

# Optional: point the CLI at a non-prod dashboard for login/deploy.
# FILTHY_PANTY_DASHBOARD_URL=https://dashboard.dev.beeblast.co
# FILTHY_PANTY_PROJECT=sandbox-stateless
# FILTHY_PANTY_ENVIRONMENT=development

# Runtime path for `bun index.ts`.
# Prefer direct Lambda Function URL config while the dashboard proxy is not
# wired with FILTHY_PANTY_AGENT_SERVICE_URL/FILTHY_PANTY_HARNESS_URL and
# FILTHY_PANTY_SERVICE_AUTH_SECRET.
#
# Account-secret auth (public direct API):
# FILTHY_PANTY_HARNESS_URL=https://<lambda-function-url>/
# FILTHY_PANTY_ACCOUNT_SECRET=fp_acct_...
#
# Service-token auth (trusted platform calls):
# FILTHY_PANTY_HARNESS_URL=https://<lambda-function-url>/
# FILTHY_PANTY_SERVICE_AUTH_SECRET=...
# FILTHY_PANTY_ACCOUNT_ID=...

# The agent references env("ACCOUNT_MINIMAX_API_KEY") in filthypanty/agents.ts.
# Store it as a deploy-time secret for the project instead of a local var:
#   bun run cli:login
#   bun ../../../filthy-panty/src/cli/index.ts env set ACCOUNT_MINIMAX_API_KEY
ACCOUNT_MINIMAX_API_KEY=
