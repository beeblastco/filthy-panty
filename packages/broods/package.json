{
  "name": "broods",
  "version": "0.1.1",
  "description": "CLI + TypeScript SDK for the broods agent platform.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/beeblastco/broods#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeblastco/broods.git",
    "directory": "packages/broods"
  },
  "bugs": {
    "url": "https://github.com/beeblastco/broods/issues"
  },
  "keywords": [
    "agents",
    "ai",
    "sdk",
    "cli",
    "broods"
  ],
  "bin": {
    "broods": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "bun scripts/build.ts && rollup -c rollup.dts.config.mjs && bun scripts/clean-dts-side-effects.ts && rm -rf .dts-temp",
    "check": "tsc --noEmit",
    "pack:check": "bun run build && npm pack --dry-run",
    "test": "bun test"
  },
  "dependencies": {
    "@chat-adapter/discord": "^4.31.0",
    "@chat-adapter/github": "^4.31.0",
    "@chat-adapter/slack": "^4.31.0",
    "@chat-adapter/telegram": "^4.31.0",
    "ai": "^6.0.195"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "rollup": "^4.53.3",
    "rollup-plugin-dts": "^6.3.0"
  }
}
