{
  "name": "@filthy-panty/docs",
  "description": "BeeBlast developer documentation site (Docusaurus).",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "DOCUSAURUS_BROWSER=none NODE_OPTIONS=--openssl-legacy-provider docusaurus start",
    "build": "NODE_OPTIONS=--openssl-legacy-provider docusaurus build",
    "serve": "DOCUSAURUS_BROWSER=none docusaurus serve",
    "deploy": "NODE_OPTIONS=--openssl-legacy-provider docusaurus deploy",
    "clear": "docusaurus clear"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.1",
    "@mdx-js/react": "^3.0.0",
    "@docusaurus/preset-classic": "^3.10.1",
    "@docusaurus/theme-mermaid": "3.10.1",
    "@mermaid-js/layout-elk": "^0.1.9",
    "@scalar/docusaurus": "^0.8.20",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@docusaurus/tsconfig": "^3.10.1",
    "@types/node": "^25.9.1",
    "webpack": "5.105.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
