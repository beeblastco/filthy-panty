# Existing core Function URL or HTTP origin that serves the direct API.
FILTHY_PANTY_CORE_URL=https://your-core-function-url.lambda-url.eu-central-1.on.aws

# In-cluster gateway deployments should use nats://nats.nats.svc.cluster.local:4222.
# Local/out-of-cluster runs can use wss://nats.beeblast.co.
NATS_URL=nats://nats.nats.svc.cluster.local:4222
# NATS_TOKEN=

# Local/container bind settings.
PORT=3000
HOSTNAME=0.0.0.0

# Per-pod guardrails. Keep the gateway stateless and scale with replicas.
GATEWAY_MAX_CONNECTIONS=10000
GATEWAY_MAX_PAYLOAD_BYTES=1048576
GATEWAY_BACKPRESSURE_BYTES=1048576
GATEWAY_IDLE_TIMEOUT_SECONDS=300
GATEWAY_RUN_START_TIMEOUT_MS=15000
