# Local development env for the agent-gateway service.
# Copy this file to .env and fill in the values.
CONVEX_SITE_URL=

# Shared secret between gateway and Convex functions (must match Convex env var)
GATEWAY_SHARED_SECRET=

# Shared secret between agent and sandbox
SANDBOX_SERVICE_URL=http://localhost:8971
SANDBOX_SHARED_SECRET=

# Tavily Search API
TAVILY_API_KEY=

# Optional pepper for API key hashing (must match Convex env var)
AGENT_API_KEY_PEPPER=

# API Key for AI Gateway from vercel
AI_GATEWAY_API_KEY=
