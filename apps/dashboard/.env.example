# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# WorkOS AuthKit
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_WEBHOOK_SECRET=
WORKOS_REDIRECT_URI=
WORKOS_COOKIE_PASSWORD=

# Filthy-panty SaaS backend
# Function URLs of the deployed filthy-panty Lambdas. Server-only.
FILTHY_PANTY_HARNESS_URL=
FILTHY_PANTY_ACCOUNT_MANAGE_URL=
# Service token shared with filthy-panty. Lets cherry-coke server-side actions
# call filthy-panty with `Authorization: Bearer <SERVICE_AUTH_SECRET>` and
# `X-Account-Id: <accountId>` without holding per-org Bearer secrets.
FILTHY_PANTY_SERVICE_AUTH_SECRET=

# Sandbox tool executor (separate service)
SANDBOX_SERVICE_URL=
SANDBOX_SHARED_SECRET=
