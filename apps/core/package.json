{
  "name": "@broods/core",
  "description": "Serverless multi-account AI agent harness on AWS Lambda — Vercel AI SDK with Google, OpenAI, Bedrock, and Gateway providers + multi-channel integrations (Telegram, Discord, Slack, GitHub, Pancake, Zalo), deployed with SST.",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "bun run scripts/system-prompt.ts && sst install",
    "dev": "bun run scripts/system-prompt.ts && sst dev",
    "build": "bun run scripts/build.ts",
    "check": "bun run scripts/system-prompt.ts && bunx tsc --noEmit",
    "test": "bun test --max-concurrency=1",
    "daytona:s3-snapshot": "bun run scripts/daytona-s3-snapshot.ts",
    "deploy": "bun run build && sst deploy",
    "remove": "sst remove"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.161",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.112",
    "@ai-sdk/anthropic": "^3.0.83",
    "@ai-sdk/gateway": "^3.0.123",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/openai": "^3.0.67",
    "@ai-sdk/provider": "^3.0.1",
    "@aws-sdk/client-cloudwatch-logs": "^3.1060.0",
    "@aws-sdk/client-dynamodb": "3.1017.0",
    "@aws-sdk/client-lambda": "3.1017.0",
    "@aws-sdk/client-lambda-microvms": "^3.1075.0",
    "@aws-sdk/client-s3": "3.1017.0",
    "@aws-sdk/client-scheduler": "3.1017.0",
    "@aws-sdk/client-ssm": "^3.1060.0",
    "@aws-sdk/client-sts": "3.1017.0",
    "@aws-sdk/s3-request-presigner": "3.1017.0",
    "@broods/convex": "workspace:*",
    "@chat-adapter/discord": "^4.31.0",
    "@chat-adapter/github": "^4.31.0",
    "@chat-adapter/slack": "^4.31.0",
    "@chat-adapter/telegram": "^4.31.0",
    "@convex-dev/stripe": "^0.1.4",
    "@convex-dev/workos-authkit": "^0.2.6",
    "@daytona/sdk": "^0.175.0",
    "@mv37/workdir": "^0.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "0.217.0",
    "@opentelemetry/exporter-logs-otlp-proto": "0.217.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "0.217.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@pulumi/aws": "7.30.0",
    "@pulumi/pulumi": "3.228.0",
    "@smithy/fetch-http-handler": "^5.4.6",
    "@tavily/ai-sdk": "^0.4.1",
    "@vercel/sandbox": "^2.1.1",
    "ai": "^6.0.195",
    "chat": "^4.31.0",
    "convex": "^1.40.0",
    "e2b": "^2.27.1",
    "nats": "^2.29.3",
    "nats.ws": "^1.30.3",
    "sst": "4.8.0",
    "vercel-minimax-ai-provider": "^0.0.2"
  }
}
