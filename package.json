{
  "name": "filthy-panty",
  "description": "Agentic AI chatbot on AWS — Lambda + Google AI + Telegram, deployed with SST.",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "bun run scripts/system-prompt.ts && sst install",
    "dev": "bun run scripts/system-prompt.ts && sst dev",
    "build": "bun run scripts/build.ts",
    "check": "bun run scripts/system-prompt.ts && bunx tsc --noEmit",
    "test": "bun test",
    "discord:sync": "bun run scripts/discord-sync.ts",
    "deploy": "bun run build && sst deploy",
    "remove": "sst remove"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.161",
    "@types/bun": "^1.3.13"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.66",
    "@aws-sdk/client-dynamodb": "3.1017.0",
    "@aws-sdk/client-lambda": "3.1017.0",
    "@aws-sdk/client-s3": "^3.1040.0",
    "@chat-adapter/telegram": "^4.27.0",
    "@pulumi/aws": "7.23.0",
    "@pulumi/pulumi": "3.228.0",
    "@tavily/ai-sdk": "^0.4.1",
    "@types/node": "^25.6.0",
    "ai": "^6.0.172",
    "chat": "^4.27.0",
    "sst": "4.8.0"
  }
}
