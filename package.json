{
  "name": "filthy-panty",
  "description": "Agentic AI chatbot on AWS — Lambda + Google AI + Telegram, deployed with SST.",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "sst install",
    "dev": "sst dev",
    "build": "bun run scripts/build.ts",
    "check": "bunx tsc --noEmit",
    "deploy": "bun run build && sst deploy",
    "remove": "sst remove"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.161",
    "@types/bun": "^1.3.12"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@aws-sdk/client-dynamodb": "3.1017.0",
    "@pulumi/aws": "7.23.0",
    "@pulumi/pulumi": "3.228.0",
    "@types/node": "^25.6.0",
    "ai": "^6.0.168",
    "sst": "4.8.0"
  }
}
